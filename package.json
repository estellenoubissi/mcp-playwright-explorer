{
  "name": "mcp-playwright-explorer",
  "version": "1.0.0",
  "description": "AI-powered exploratory test agent using Playwright + MCP",
  "main": "dist/index.js",
  "scripts": {
    "start": "ts-node -r dotenv/config src/index.ts",
    "build": "tsc",
    "test": "jest",
    "test:e2e": "playwright test",
    "mcp:server": "ts-node -r dotenv/config src/mcp/server.ts",
    "explore": "ts-node -r dotenv/config src/index.ts explore",
    "explore:submenus": "ts-node -r dotenv/config src/index.ts explore-submenus",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/estellenoubissi/mcp-playwright-explorer.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/estellenoubissi/mcp-playwright-explorer/issues"
  },
  "homepage": "https://github.com/estellenoubissi/mcp-playwright-explorer#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@playwright/test": "^1.58.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "groq-sdk": "^1.1.1",
    "js-yaml": "^4.1.1",
    "openai": "^6.32.0",
    "ora": "^9.3.0",
    "playwright": "^1.58.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/unit/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ]
  }
}
