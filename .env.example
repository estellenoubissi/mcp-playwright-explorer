ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Provider Groq (FREE - https://console.groq.com/)
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

BASE_URL=http://localhost:3000
TARGET_FEATURE=login
HEADLESS=true
BROWSER=chromium
MCP_TRANSPORT=stdio
MCP_LOG_LEVEL=info
OUTPUT_DIR=outputs
SCREENSHOTS_DIR=outputs/screenshots
REPORTS_DIR=outputs/reports

# ============================================
# AUTHENTIFICATION (optionnel)
# ============================================
# Activer l'auth avant l'exploration
AUTH_ENABLED=false

# URL de la page de login
AUTH_URL=https://monsite.com/login

# Credentials LDAP (ne jamais committer les vraies valeurs !)
AUTH_USERNAME=mon_login_ldap
AUTH_PASSWORD=mon_password_ldap

# Sélecteurs du formulaire (optionnel - valeurs par défaut pour formulaires LDAP en français)
# AUTH_USERNAME_SELECTOR=#username
# AUTH_PASSWORD_SELECTOR=#password
# AUTH_SUBMIT_SELECTOR=#login_ok
# AUTH_USERNAME_LABEL=Nom d'utilisateur
# AUTH_PASSWORD_LABEL=Mot de passe

# Textes du bouton d'avertissement SSL (optionnel - valeurs par défaut pour Chrome en français)
# AUTH_SSL_BUTTON=Paramètres avancés
# AUTH_SSL_CONTINUE=Continuer vers le site
